# Adzuna Jobs API
# Get credentials at https://developer.adzuna.com (free tier available)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Slack Incoming Webhook
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Google Sheet ID
# Found in the sheet URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id

# n8n API Key (only needed if using the n8n REST API to activate/deactivate)
N8N_API_KEY=your_n8n_api_key
